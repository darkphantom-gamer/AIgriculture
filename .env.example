# AIgriculture — environment template.
# Copy to ".env" and fill in your own values:  cp .env.example .env
# Nothing here is required to boot the dashboard; empty values just disable that feature.

# ─── Dashboard login (first boot seeds the DB with this user) ──────────────
# Set your own. If ADMIN_PASS is left blank, a random one is generated and
# printed to the log on first boot.
ADMIN_USER=admin
ADMIN_PASS=

# Session signing key. Leave blank to auto-generate one on first run.
JWT_SECRET=

# ─── MySQL / MariaDB (used for users + sessions) ───────────────────────────
# Install with: sudo apt install mariadb-server, then create the DB:
#   sudo mysql -e "CREATE DATABASE plantmonitor;
#                  CREATE USER 'plantmonitor'@'localhost' IDENTIFIED BY 'CHANGE-ME';
#                  GRANT ALL ON plantmonitor.* TO 'plantmonitor'@'localhost';"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=plantmonitor
DB_PASS=change-this-password
DB_NAME=plantmonitor

# ─── SMTP for email reports / alerts (optional) ───────────────────────────
# Gmail App Password (no spaces), Hostinger SMTP, or any SMTP server.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# ─── FLORA AI assistant (optional) ─────────────────────────────────────────
# FLORA runs fully OFFLINE if no keys are set — cloud chat just won't be available.
# All have free tiers (as of 2026):
#   Groq      https://console.groq.com      (recommended, fast)
#   Cerebras  https://cloud.cerebras.ai      (very fast)
#   Mistral   https://console.mistral.ai     (good tool calling)
#   Gemini    https://aistudio.google.com    (lower daily cap)
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
# Optional: extra Gemini keys for round-robin, comma-separated.
GEMINI_API_KEYS=

# ─── Meshtastic LoRa bridge (optional) ─────────────────────────────────────
# Lets you chat with FLORA over a LoRa mesh radio. Needs meshtasticd running.
MESH_ENABLED=false
MESH_HOST=localhost
# Comma-separated node IDs allowed to talk to FLORA. Blank = allow all.
MESH_ALLOWED_NODES=
# Reply only on the same channel/DM the message arrived on.
MESH_REPLY_MODE=reply

# ─── Security camera (CPU YOLO) — only used by main.py ────────────────────
# Lower SECURITY_FRAME_SKIP for snappier detection at higher CPU cost
# (1 = every frame, 10 = every 10th frame; default 5 is sane on a Pi 5).
SECURITY_FRAME_SKIP=5
SECURITY_IMGSZ=480
SECURITY_MODEL=yolov8n.pt

# ─── Security camera (Hailo) — only used by main-hailo.py ─────────────────
PLANTWATCH_SECURITY_HEF=

# ─── Hardware overrides (optional — most users don't need these) ──────────
# Path to a custom wiring file; defaults to ./wiring.yaml beside main.py.
WIRING_FILE=
# Where to store captured plant-health and security photos.
PLANTWATCH_STORAGE=
