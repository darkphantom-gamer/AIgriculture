# AIgriculture — environment template.
# Copy to ".env" and fill in your own values:  cp .env.example .env
# Nothing here is required to boot the dashboard; empty values just disable that feature.

# ─── Dashboard login (first boot seeds the DB with this user) ──────────────
# Set your own. If ADMIN_PASS is left blank, a random one is generated and
# printed to the log on first boot.
ADMIN_USER=admin
ADMIN_PASS=

# Session signing key. Leave blank to auto-generate one on first run.
JWT_SECRET=

# ─── MySQL / MariaDB (used for users + sessions) ───────────────────────────
# Install with: sudo apt install mariadb-server, then create the DB:
#   sudo mysql -e "CREATE DATABASE plantmonitor;
#                  CREATE USER 'plantmonitor'@'localhost' IDENTIFIED BY 'CHANGE-ME';
#                  GRANT ALL ON plantmonitor.* TO 'plantmonitor'@'localhost';"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=plantmonitor
DB_PASS=change-this-password
DB_NAME=plantmonitor

# ─── SMTP for email reports / alerts (optional) ───────────────────────────
# Gmail App Password (no spaces), Hostinger SMTP, or any SMTP server.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# ─── FLORA AI assistant (optional) ─────────────────────────────────────────
# FLORA runs fully OFFLINE if no keys are set — cloud chat just won't be available.
# All have free tiers (as of 2026):
#   Groq      https://console.groq.com      (recommended, fast)
#   Cerebras  https://cloud.cerebras.ai      (very fast)
#   Mistral   https://console.mistral.ai     (good tool calling)
#   Gemini    https://aistudio.google.com    (lower daily cap)
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
# Optional: extra Gemini keys for round-robin, comma-separated.
GEMINI_API_KEYS=

# ─── Meshtastic LoRa bridge (optional) ─────────────────────────────────────
# Lets you chat with FLORA over a LoRa mesh radio. Needs meshtasticd running.
MESH_ENABLED=false
MESH_HOST=localhost
# Comma-separated node IDs allowed to talk to FLORA. Blank = allow all.
MESH_ALLOWED_NODES=
# Reply only on the same channel/DM the message arrived on.
MESH_REPLY_MODE=reply

# ─── Security camera (CPU YOLO) — only used by main.py ────────────────────
# Defaults are tuned for "noticeable but not paranoid" accuracy on a Pi 5:
#   yolov8s.pt (small, ~22 MB) — better recall on person / bear / elephant /
#   cow / dog / horse / cat / sheep / bird / zebra than the 6 MB yolov8n.
#   imgsz=640 matches what Ultralytics trained on, helps small / distant
#   subjects (a person at 30 px is below the noise floor at 480).
# Need more FPS? SECURITY_MODEL=yolov8n.pt + SECURITY_IMGSZ=480 still works.
# Need even more accuracy? Try yolov8m.pt (52 MB) — slower per frame.
# SECURITY_FRAME_SKIP: 1 = every frame, 10 = every 10th frame; 5 is sane on Pi 5.
SECURITY_FRAME_SKIP=5
SECURITY_IMGSZ=640
SECURITY_MODEL=yolov8s.pt

# ─── Security camera (Hailo) — only used by main-hailo.py ─────────────────
PLANTWATCH_SECURITY_HEF=

# ─── FarmMonitor camera (disease / ripeness scans) ────────────────────────
# Auto-detects the first USB camera on /dev/video* if left blank. To use a
# CSI (RPi) camera, launch with --use-rpicam OR set FARM_MONITOR_CAMERA=rpi.
# To use an IP / RTSP / HTTP-MJPEG stream, point this at the URL.
# Examples:
#   FARM_MONITOR_CAMERA=/dev/video0                        # USB
#   FARM_MONITOR_CAMERA=rpi                                # RPi CSI (via OpenCV)
#   FARM_MONITOR_CAMERA=rtsp://user:pass@192.168.1.10/live # IP RTSP
#   FARM_MONITOR_CAMERA=http://camera.example/cam.cgi      # IP MJPEG / HTTP
# CLI override (highest priority):  python main.py --farm-cam <source>
FARM_MONITOR_CAMERA=

# ─── Custom crop models (versatile — not just strawberry) ─────────────────
# Drop your own YOLOv8 .pt files into the Models/ folder and point these envs
# at them to scan tomatoes, mangoes, grapes, peppers, lettuce — any crop you
# trained a model for. Labels JSONs control class-name → display + color.
# Templates:  farm_monitor_disease_labels.json / farm_monitor_ripeness_labels.json
# DISEASE_MODEL_PATH=Models/Disease_detect.pt
# RIPENESS_MODEL_PATH=Models/Ripeness_detect.pt
# DISEASE_LABELS_PATH=farm_monitor_disease_labels.json
# RIPENESS_LABELS_PATH=farm_monitor_ripeness_labels.json

# ─── Hardware overrides (optional — most users don't need these) ──────────
# Path to a custom wiring file; defaults to ./wiring.yaml beside main.py.
WIRING_FILE=
# Where to store captured plant-health and security photos.
PLANTWATCH_STORAGE=

# ─── Security / debug toggles ─────────────────────────────────────────────
# Expose Swagger UI (/docs, /redoc, /openapi.json). OFF in production.
# Only set on a trusted dev box — this reveals the full API surface.
# AIGRI_PUBLIC_DOCS=1
